# Dodo Payments Configuration
VITE_DODO_PUBLIC_KEY=your_dodo_public_key_here
VITE_DODO_PRO_PLAN_ID=your_pro_plan_id
VITE_DODO_ENTERPRISE_PLAN_ID=your_enterprise_plan_id

# Dodo Webhook (Server-side only)
DODO_WEBHOOK_SECRET=your_webhook_secret

# Appwrite Configuration
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id_here
APPWRITE_API_KEY=your_api_key_here
APPWRITE_DATABASE_ID=your_database_id_here

# Dodo Webhook Collection
DODO_SUBSCRIPTION_COLLECTION_ID=your_subscriptions_collection_id_here
